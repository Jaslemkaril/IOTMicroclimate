# TerraSync — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ──────────────────────────────────
PORT=3000

# ── MySQL (XAMPP defaults) ──────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=terrasync

# ── Optional ────────────────────────────────
# NODE_ENV=development
